page "STFL Demo"

font_import "Inter"

style ".card" -> bg:white, padding:20px, radius:12, shadow:0 2px 8px rgba(0,0,0,0.1)
style ".hero" -> bg:linear-gradient(135deg, #667eea 0%, #764ba2 100%), text:white, padding:60px, radius:16

box [class=hero]:
  title "STFL":
    size = 48
    color = white
    font = Inter
    align = center

  text "Simple Text Format Language":
    size = 20
    color = white
    align = center
    opacity = 0.9

  button "Get Started":
    bg = #667eea
    color = white
    padding = 14
    radius = 10
    border = none
    weight = bold

divider

box [class=card]:
  title "Features"
  item "No closing tags — indentation-based"
  item "TXT editable — any text editor"
  item "AI friendly — optimized for LLMs"
  item "Inline CSS system — style without CSS files"
  item "Box containers — auto-indent layout engine"
  item "Iconify support — 100,000+ icons"

divider

title "Icon Gallery":
  size = 28
  align = center

icon "mdi:github":
  size = 48
  color = #333

icon "logos:python":
  size = 48

icon "ph:rocket-launch-duotone":
  size = 48
  color = #667eea

divider

link "GitHub Repository" -> https://github.com

svg "<svg viewBox='0 0 24 24'><circle cx='12' cy='12' r='10' fill='#667eea'/></svg>"

text "Built with STFL":
  color = gray
  size = 14
  align = center
